generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlayHistory {
  id        Int      @id @default(autoincrement())
  score     Int
  createdAt DateTime @default(now())
}

model RewardHistory {
  id        Int      @id @default(autoincrement())
  reward    String
  claimedAt DateTime @default(now())
}

model GameState {
  id         Int @id @default(autoincrement())
  totalScore Int @default(0)
}
